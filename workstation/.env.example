# =====================================================
# Workstation Environment Template
# 使用方式：
# 1) cp workstation/.env.example workstation/.env
# 2) 根据本地环境调整
# =====================================================

# 是否启用 mock
REACT_APP_USE_MOCK=false

# API 基础地址：
# - 留空时配合 request.js 走相对路径 + /api 前缀
# - 指定绝对地址时可直连网关
APP_BASE_URL=
VITE_API_BASE_URL=/api

# 验证码说明：
# 当前登录页优先使用后端 /api/captcha/config 下发 provider 与 site key。
# 该变量仅作历史兼容保留，可留空。
REACT_APP_TURNSTILE_SITE_KEY=

# 本地开发可选项
DEPLOYED_ENV=Local
PORT=3000
PUBLIC_URL=''
IFRAME_ORIGIN=http://localhost:3000

# GitHub OAuth（按需启用）
REACT_APP_GITHUB_CLIENT_ID=
REACT_APP_GITHUB_CLIENT_SECRET=
REACT_APP_GITHUB_REDIRECT_URI=http://localhost:3000/auth/callback
