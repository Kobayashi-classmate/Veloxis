{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Hello Chart Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "default": "Hello Chart"
    },
    "palette": {
      "type": "string",
      "enum": ["default", "ocean", "sunset"],
      "default": "default"
    },
    "showLegend": {
      "type": "boolean",
      "default": true
    }
  }
}
