# =====================================================
# Veloxis Root Environment Template
# 使用方式：
# 1) cp .env.example .env
# 2) 按实际环境替换所有占位值
# =====================================================

# 基础配置
PROJECT_NAME=Veloxis
# Directus 后台路径前缀（需保留前导 /）
ADMIN_BASE_PATH=/replace-with-random-path

# Directus 初始化管理员
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-strong-password

# Directus 核心密钥（建议使用 uuidgen 生成）
KEY=replace-with-uuid
SECRET=replace-with-uuid

# SeaweedFS S3 访问凭据
S3_ACCESS_KEY=replace-with-access-key
S3_SECRET_KEY=replace-with-secret-key

# Cube.js / Doris 连接
CUBEJS_API_SECRET=replace-with-cube-secret
CUBEJS_DB_TYPE=mysql
CUBEJS_DB_HOST=doris-fe
CUBEJS_DB_PORT=9030
CUBEJS_DB_NAME=veloxis_data
CUBEJS_DB_USER=root
CUBEJS_DB_PASS=

# PostgreSQL（Directus 元数据库）
POSTGRES_USER=directus
POSTGRES_PASSWORD=replace-with-db-password
POSTGRES_DB=directus

# =====================================================
# Captcha / Auth Gateway
# =====================================================
# internal | turnstile
CAPTCHA_PROVIDER=internal

# true: 严格失败关闭（推荐）
CAPTCHA_FAIL_CLOSED=true

# challenge 与 ticket TTL（秒）
CAPTCHA_CHALLENGE_TTL_SECONDS=120
CAPTCHA_TICKET_TTL_SECONDS=120

# captchaTicket HMAC 密钥（建议独立于 SECRET）
CAPTCHA_TICKET_SECRET=replace-with-captcha-ticket-secret

# Turnstile（仅 provider=turnstile 时需要）
CAPTCHA_TURNSTILE_SITE_KEY=
CAPTCHA_TURNSTILE_SECRET=
